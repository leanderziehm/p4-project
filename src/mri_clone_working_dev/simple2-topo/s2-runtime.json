{
  "target": "bmv2",
  "p4info": "build/mri.p4.p4info.txt",
  "bmv2_json": "build/mri.json",
  "table_entries": [
    {
      "table": "MyEgress.swtrace",
      "default_action": true,
      "action_name": "MyEgress.add_swtrace",
      "action_params": { "swid": 2, "ecn_threshold": 500 }
    },
    {
      "table": "MyIngress.last_hop",
      "match": { "hdr.ipv4.dstAddr": ["10.0.2.2", 32] },
      "action_name": "MyIngress.do_clone",
      "action_params": {"sinkAddr":"10.0.3.3","sinkPort": 3}
    },
    {
      "table": "MyIngress.ipv4_lpm",
      "match": {"hdr.ipv4.dstAddr": ["10.0.1.1",32] },
      "action_name": "MyIngress.ipv4_forward",
      "action_params": { "dstAddr": "08:00:00:00:01:01","port": 1 }
    },
    {
      "table": "MyIngress.ipv4_lpm",
      "match": {"hdr.ipv4.dstAddr": ["10.0.2.2",32] },
      "action_name": "MyIngress.ipv4_forward",
      "action_params": { "dstAddr": "08:00:00:00:02:02","port": 2 }
    },
    {
      "table": "MyIngress.ipv4_lpm",
      "match": {"hdr.ipv4.dstAddr": ["10.0.3.3",32] },
      "action_name": "MyIngress.ipv4_forward",
      "action_params": { "dstAddr": "08:00:00:00:03:03","port": 3 }
    }
  ],
  "clone_session_entries": [
    {
      "clone_session_id": 99,
      "replicas": [
        {
          "egress_port": 3,
          "instance": 1
        }
      ],
      "packet_length_bytes": 0
    }
  ]
}